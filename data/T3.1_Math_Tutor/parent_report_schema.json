{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WeeklyParentReport",
  "type": "object",
  "required": ["learner_id", "week_ending", "summary", "skills", "streaks"],
  "properties": {
    "learner_id": { "type": "string" },
    "week_ending": { "type": "string", "format": "date" },
    "summary": { "type": "object" },
    "skills": { "type": "array" },
    "streaks": { "type": "object" }
  }
}
